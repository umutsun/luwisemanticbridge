{
  "code": "tr",
  "name": "Türkçe",
  "description": "Turkish legal/tax domain sanitizer patterns",

  "temporalUnits": ["yıl", "ay", "gün", "hafta", "saat"],

  "temporalSuffixes": {
    "description": "Turkish verb suffix patterns for temporal claims (vowel harmony)",
    "backVowels": "d[ıi]r",
    "frontVowels": "d[üu]r"
  },

  "datePatterns": {
    "ordinal": "(\\d+)[''ıiuü](?:n[aeiıoöuü]|s[ıi])",
    "description": "Turkish date ordinals: 26'sı, ayın 15'i"
  },

  "percentagePatterns": {
    "symbol": "%\\s*(\\d+)",
    "word": "yüzde\\s*(\\d+)",
    "description": "Turkish percentage: %18, yüzde 20"
  },

  "forbiddenPatterns": [
    {
      "id": "norm-1",
      "category": "normative",
      "pattern": "gerek(?:mektedir|ir|iyor|lidir|tirmektedir|tirir)(?:ler)?(?=[.,;\\s]|$)",
      "description": "Gerekmektedir varyantları"
    },
    {
      "id": "norm-2",
      "category": "normative",
      "pattern": "zorunlu(?:dur|luktur)?(?:lar)?(?=[.,;\\s]|$)",
      "description": "Zorunludur"
    },
    {
      "id": "norm-3",
      "category": "normative",
      "pattern": "zorundadır(?:lar|s[ıi]n[ıi]z)?(?=[.,;\\s]|$)",
      "description": "Zorundadır + çekimler"
    },
    {
      "id": "norm-4",
      "category": "normative",
      "pattern": "mecbur(?:dur|idir|iyet)?(?:lar)?(?=[.,;\\s]|$)",
      "description": "Mecburdur/mecburiyet"
    },
    {
      "id": "norm-5",
      "category": "normative",
      "pattern": "şart(?:tır)?(?:lar)?(?=[.,;\\s]|$)",
      "description": "Şarttır"
    },
    {
      "id": "norm-6",
      "category": "normative",
      "pattern": "yükümlü(?:dür)?(?:ler)?(?=[.,;\\s]|$)",
      "description": "Yükümlüdür"
    },
    {
      "id": "modal-1",
      "category": "modal",
      "pattern": "verilmelidir(?:ler)?(?=[.,;\\s]|$)",
      "description": "Verilmelidir"
    },
    {
      "id": "modal-2",
      "category": "modal",
      "pattern": "yapılmalıdır(?:lar)?(?=[.,;\\s]|$)",
      "description": "Yapılmalıdır"
    },
    {
      "id": "modal-3",
      "category": "modal",
      "pattern": "edilmelidir(?:ler)?(?=[.,;\\s]|$)",
      "description": "Edilmelidir"
    },
    {
      "id": "modal-4",
      "category": "modal",
      "pattern": "saklanmalıdır(?:ler)?(?=[.,;\\s]|$)",
      "description": "Saklanmalıdır"
    },
    {
      "id": "cons-1",
      "category": "consequence",
      "pattern": "aksi\\s+(?:takdirde|halde|durumda)",
      "description": "Aksi takdirde/halde"
    },
    {
      "id": "cons-2",
      "category": "consequence",
      "pattern": "(?:hak|indirim|iade)\\s+kayb",
      "description": "Hak/indirim kaybı"
    },
    {
      "id": "warn-1",
      "category": "modal",
      "pattern": "unutulmamalıdır",
      "description": "Unutulmamalıdır"
    },
    {
      "id": "warn-2",
      "category": "modal",
      "pattern": "dikkat\\s+edilmelidir",
      "description": "Dikkat edilmelidir"
    }
  ],

  "groundingKeywords": [
    "fatura", "makbuz", "fiş", "belge", "form", "dilekçe",
    "sözleşme", "protokol", "tutanak", "rapor",
    "madde", "fıkra", "bent", "kanun", "yönetmelik", "tebliğ",
    "matrah", "vergi", "kdv", "stopaj", "tevkifat",
    "tahakkuk", "tahsil", "iade", "indirim", "mahsup",
    "süre", "gün", "ay", "yıl", "tarih", "vade", "dönem",
    "saklama", "muhafaza", "ibraz", "arşiv",
    "beyanname", "bildirim", "başvuru",
    "ceza", "usulsüzlük", "gecikme", "faiz"
  ],

  "numberWords": {
    "description": "Turkish number word ↔ digit mappings for claim verification",
    "cardinals": {
      "bir": 1, "iki": 2, "üç": 3, "dört": 4, "beş": 5,
      "altı": 6, "yedi": 7, "sekiz": 8, "dokuz": 9, "on": 10,
      "onbir": 11, "oniki": 12, "onüç": 13, "ondört": 14, "onbeş": 15,
      "onaltı": 16, "onyedi": 17, "onsekiz": 18, "ondokuz": 19, "yirmi": 20,
      "yirmibir": 21, "yirmiiki": 22, "yirmiüç": 23, "yirmidört": 24, "yirmibeş": 25,
      "yirmialtı": 26, "yirmiyedi": 27, "yirmisekiz": 28, "yirmidokuz": 29, "otuz": 30,
      "otuzbir": 31, "kırk": 40, "elli": 50, "altmış": 60, "yetmiş": 70,
      "seksen": 80, "doksan": 90, "yüz": 100
    },
    "ordinals": {
      "birinci": 1, "ikinci": 2, "üçüncü": 3, "dördüncü": 4, "beşinci": 5,
      "altıncı": 6, "yedinci": 7, "sekizinci": 8, "dokuzuncu": 9, "onuncu": 10,
      "onbirinci": 11, "onikinci": 12, "onüçüncü": 13, "ondördüncü": 14, "onbeşinci": 15,
      "onaltıncı": 16, "onyedinci": 17, "onsekizinci": 18, "ondokuzuncu": 19, "yirminci": 20,
      "yirmibirinci": 21, "yirmiikinci": 22, "yirmiüçüncü": 23, "yirmidördüncü": 24, "yirmibeşinci": 25,
      "yirmialtıncı": 26, "yirmiyedinci": 27, "yirmisekizinci": 28, "yirmidokuzuncu": 29, "otuzuncu": 30,
      "otuzbirinci": 31
    },
    "compoundPattern": "(?:on|yirmi|otuz)\\s+(?:bir|iki|üç|dört|beş|altı|yedi|sekiz|dokuz)",
    "ordinalSuffix": "(?:[iıuü]nc[iıuü])"
  }
}
