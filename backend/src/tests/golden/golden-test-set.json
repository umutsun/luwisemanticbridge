  "invariants": {
    "responseType_FOUND": {
      "condition": "responseType === 'FOUND'",
      "assertions": [
        "sourcesCount >= 1",
        "hasCevap === true"
      ]
    },
    "responseType_NOT_FOUND": {
      "condition": "responseType === 'NOT_FOUND'",
      "assertions": [
        "sourcesCount === 0"
      ]
    },
    "responseType_NEEDS_CLARIFICATION": {
      "condition": "responseType === 'NEEDS_CLARIFICATION'",
      "assertions": [
        "sourcesCount === 0",
        "response does NOT contain ALINTI",
        "hasSuggestions === true"
      ]
    },
    "responseType_OUT_OF_SCOPE": {
      "condition": "responseType === 'OUT_OF_SCOPE'",
      "assertions": [
        "sourcesCount === 0",
        "response does NOT contain ALINTI"
      ]
    },
    "early_exit_ambiguity": {
      "condition": "earlyExit === true && responseType === 'NEEDS_CLARIFICATION'",
      "assertions": [
        "sourcesCount === 0",
        "no LLM call made",
        "response is template"
      ]
    },
    "early_exit_out_of_scope": {
      "condition": "earlyExit === true && responseType === 'OUT_OF_SCOPE'",
      "assertions": [
        "sourcesCount === 0",
        "no LLM call made",
        "response is template"
      ]
    },
    "verdict_question_no_quote": {
      "condition": "verdictQuestion === true && hasAlinti === false",
      "assertions": [
        "response does NOT contain 'mümkün olabilir'",
        "response does NOT contain 'asılamayabilir'",
        "response does NOT contain 'zorunlu olabilir'",
        "response contains 'hüküm cümlesi' or 'seçilemedi'"
      ]
    }
  },
  "ciGate": {
    "required": true,
    "description": "Deploy gate must pass mini-test-kit (8 tests) before deployment",
    "failOnViolation": true,
    "miniTestKitTests": [
      1,
      2,
      3,
      4,
      5,
      6,
      7,
      8
    ],
    "criticalInvariants": [
      "early_exit_ambiguity",
      "early_exit_out_of_scope",
      "verdict_question_no_quote"
    ]
  }
