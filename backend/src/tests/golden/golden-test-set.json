{
  "version": "1.3",
  "created": "2026-01-11",
  "updated": "2026-01-11",
  "description": "Golden test set for RAG pipeline regression testing - 50 Questions (v1.3)",
  "acceptanceCriteria": {
    "1_early_exit_guards": {
      "description": "Strong ambiguity and out-of-scope queries exit BEFORE retrieval/LLM",
      "rule": "justNumbers/vagueQuestion/singleToken → NEEDS_CLARIFICATION immediately | outOfScopePattern → OUT_OF_SCOPE immediately"
    },
    "2_verdict_no_quote_no_verdict": {
      "description": "Verdict questions without quote get 'hüküm cümlesi seçilemedi' - NO half-verdicts",
      "rule": "If verdict question + no ALINTI → response must be 'kaynak var ancak hüküm cümlesi seçilemedi' with sources"
    },
    "3_section_finder_correct": {
      "description": "Section finder targets correct parts of document",
      "rule": "Özelge: Açıklamalar/Sonuç/Cevap | Danıştay: HÜKÜM/SONUÇ/Karar | Kanun: Madde"
    },
    "4_quote_scorer_hard_filter": {
      "description": "dilekçe/tereddüt sentences are NEVER selected as quotes",
      "rule": "Hard filter (skip), not penalty - these sentences cannot win even with high term matches"
    },
    "5_response_type_deterministic": {
      "description": "ResponseType is purely based on early exit + results count + scope - NO LLM pattern matching",
      "rule": "earlyAmbiguity → NEEDS_CLARIFICATION | earlyOutOfScope → OUT_OF_SCOPE | results > 0 → FOUND | results == 0 + inScope → NOT_FOUND"
    },
    "6_source_display": {
      "description": "FOUND shows sources, all others show sources=[]",
      "rule": "ONLY FOUND has sources, others ALWAYS sources=[]"
    },
    "7_procedural_evidence_first": {
      "description": "Procedural questions require documentary evidence",
      "rule": "nereye yazılır/hangi alana/kaç gün → ALINTI required, no specific claims without document proof"
    }
  },
  "miniTestKit": {
    "description": "8 critical questions that MUST pass before deployment",
    "tests": [
