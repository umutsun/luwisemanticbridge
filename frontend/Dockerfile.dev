FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm ci

# Copy source code
COPY . .

# Create .env file for development
RUN echo "NEXT_PUBLIC_API_URL=http://localhost:8083" > .env.local

# Expose port
EXPOSE 3000

# Start development server
CMD ["npm", "run", "dev"]