{
    "id": "modern",
    "name": "Modern",
    "description": "Sleek dark theme with glassmorphism effects",
    "version": "1.0.0",
    "extends": "base",
    "theme": {
        "primaryColor": "#8b5cf6",
        "secondaryColor": "#1e293b",
        "backgroundColor": "#0f172a",
        "panelBackground": "rgba(30, 41, 59, 0.7)",
        "textColor": "#f8fafc",
        "borderRadius": "16px",
        "fontFamily": "Inter, sans-serif",
        "messageSpacing": "1.5rem",
        "headerHeight": "70px"
    },
    "features": {
        "showLogo": true,
        "showSuggestions": true,
        "showSources": true,
        "showTimestamp": true,
        "showAvatar": true,
        "enableFullPage": true,
        "enableVoiceInput": false,
        "enableFileUpload": true
    },
    "customCSS": ".glass-panel { background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.1); }"
}