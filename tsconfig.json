{
  "compilerOptions": {
    "target": "ES2019",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": [
      "ES2020"
    ],
    "declaration": true,
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "credentials/**/*.ts",
    "index.ts",
    "nodes/AliceSemanticBridge.node.ts",
    "nodes/PgvectorQuery.node.ts",
    "nodes/PgvectorUpsert.node.ts",
    "nodes/RedisPublish.node.ts",
    "nodes/WebScrape.node.ts",
    "shared/**/*.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "nodes/*Enhanced*.ts",
    "nodes/DocumentProcessor.node.ts"
  ]
}
