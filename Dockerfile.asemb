# Multi-stage Dockerfile for Luwi Semantic Bridge
# Stage 1: Dependencies
FROM node:20-alpine AS deps
WORKDIR /app

# Install system dependencies
RUN apk add --no-cache python3 make g++ curl

# Copy package files
COPY backend/package*.json ./backend/
COPY frontend/package*.json ./frontend/

# Install backend dependencies
WORKDIR /app/backend
RUN npm ci --only=production
RUN cp -R node_modules prod_node_modules
RUN npm ci

# Install frontend dependencies
WORKDIR /app/frontend
RUN npm ci

# Stage 2: Builder
FROM node:20-alpine AS builder
WORKDIR /app

# Copy dependencies
COPY --from=deps /app/backend/node_modules ./backend/node_modules
COPY --from=deps /app/frontend/node_modules ./frontend/node_modules

# Copy source
COPY backend ./backend
COPY frontend ./frontend
COPY .env.example .env.example

# Build frontend
WORKDIR /app/frontend
RUN npm run build

# Stage 3: Runner
FROM node:20-alpine AS runner
WORKDIR /app

# Install runtime dependencies
RUN apk add --no-cache curl bash tini

# Create app user
RUN addgroup -g 1001 -S nodejs
RUN adduser -S nextjs -u 1001

# Copy production dependencies
COPY --from=deps --chown=nextjs:nodejs /app/backend/prod_node_modules ./backend/node_modules

# Copy built application
COPY --from=builder --chown=nextjs:nodejs /app/backend ./backend
COPY --from=builder --chown=nextjs:nodejs /app/frontend/.next ./frontend/.next
COPY --from=builder --chown=nextjs:nodejs /app/frontend/public ./frontend/public
COPY --from=builder --chown=nextjs:nodejs /app/frontend/package.json ./frontend/package.json

# Copy startup script
COPY --chown=nextjs:nodejs docker/startup.sh /app/startup.sh
RUN chmod +x /app/startup.sh

# Create necessary directories
RUN mkdir -p /app/.claude /app/.gemini /app/.codex /app/logs
RUN chown -R nextjs:nodejs /app

USER nextjs

EXPOSE 3000 8083

# Use tini to handle signals properly
ENTRYPOINT ["/sbin/tini", "--"]
CMD ["/app/startup.sh"]
