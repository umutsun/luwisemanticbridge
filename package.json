{
  "name": "alice-semantic-bridge",
  "version": "1.0.0",
  "description": "Multi-agent orchestration system with semantic bridge",
  "main": "start-dev.js",
  "scripts": {
    "dev": "node start-dev.js",
    "dev:api": "cd api && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "start": "pm2 start ecosystem.config.js",
    "start:prod": "pm2 start ecosystem.config.js --env production",
    "stop": "pm2 stop all",
    "restart": "pm2 restart all",
    "logs": "pm2 logs",
    "status": "pm2 status",
    "monit": "pm2 monit",
    "docker:dev": "docker-compose -f docker-compose.simple.yml up",
    "docker:prod": "docker-compose -f docker-compose.simple.yml up -d",
    "setup": "npm install -g pm2 && npm install",
    "docker:local": "docker-compose -f docker-compose.dev.yml --env-file .env.asemb up --build -d",
    "docker:server": "docker-compose -f docker-compose.prod.yml --env-file .env.asemb up --build -d",
    "docker:db": "docker-compose -f docker-compose.db-only.yml up -d",
    "docker:stop": "docker-compose -f docker-compose.dev.yml --env-file .env.asemb down",
    "docker:logs": "docker-compose -f docker-compose.dev.yml --env-file .env.asemb logs -f",
    "docker:status": "docker-compose -f docker-compose.dev.yml --env-file .env.asemb ps",
    "docker:clean": "docker system prune -f",
    "docker:restart": "docker-compose -f docker-compose.dev.yml --env-file .env.asemb restart",
    "docker:update": "docker-compose -f docker-compose.dev.yml --env-file .env.asemb pull && docker-compose -f docker-compose.dev.yml --env-file .env.asemb up --build -d"
  },
  "dependencies": {
    "axios": "^1.12.2",
    "dotenv": "^17.2.3",
    "http-proxy": "^1.18.1",
    "pm2": "^5.3.0",
    "redis": "^5.8.3"
  },
  "keywords": [
    "multi-agent",
    "semantic-bridge",
    "ai",
    "orchestration",
    "pm2",
    "nextjs",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "24.7.2",
    "@types/react": "19.2.2",
    "typescript": "5.9.3"
  }
}
