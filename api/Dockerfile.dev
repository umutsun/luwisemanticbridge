# Development Dockerfile for API Service
# Optimized for hot-reload development with volume mounts

# Use the official Node.js 20 Alpine image as a base
FROM node:20-alpine

# Install development dependencies globally
RUN npm install -g nodemon

# Set the working directory in the container
WORKDIR /app

# Create app user for security
RUN addgroup -g 1001 -S nodejs && \
    adduser -S nextjs -u 1001

# Copy package.json and package-lock.json from the 'api' directory
COPY package*.json ./

# Install ALL dependencies (including dev dependencies)
RUN npm install --legacy-peer-deps

# Copy all files from the 'api' directory into the container's working directory
COPY . .

# Create directories for workspaces and config
RUN mkdir -p /workspaces /config && \
    chown -R nextjs:nodejs /app /workspaces /config

# Create symlink for config
RUN ln -sf /app/config/config.json /config/config.json

# Expose the port the app runs on
EXPOSE 8083

# Switch to non-root user for security
USER nextjs

# The command to run the application in development mode with hot-reload
CMD ["nodemon", "server.js"]