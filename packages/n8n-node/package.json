{
  "name": "n8n-nodes-luwi-semantic-bridge",
  "version": "2.0.0",
  "description": "Connect to Luwi Chat API, format responses for Telegram/WhatsApp/Discord/Slack, and generate media",
  "main": "index.js",
  "license": "MIT",
  "author": "Luwi <info@luwi.dev>",
  "homepage": "https://luwi.dev",
  "scripts": {
    "dev": "npm run watch",
    "build": "tsc && npm run build:icons",
    "build:icons": "gulp build:icons",
    "watch": "tsc --watch",
    "lint": "eslint nodes credentials --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/LuwiSemanticBridgeApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/LuwiSemanticBridge.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "gulp": "^4.0.2",
    "n8n-workflow": "^1.25.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "openai": "^4.26.1"
  }
}